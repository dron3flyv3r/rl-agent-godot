[project]
language=C#
primary
lastDtbSucceeded

[properties]
AssemblyName=RL agent plugin
CommandLineArgsForDesignTimeEvaluation=-langversion:latest -define:TRACE
CompilerGeneratedFilesOutputPath=
MaxSupportedLangVersion=12.0
