[sub_resource type="Resource" id="TrainingConfig"]
script = ExtResource("3_traincfg")
Algorithm = SubResource("PPOConfig")

[sub_resource type="Resource" id="RunConfig_tag_hpo"]
script = ExtResource("10_runcfg")
RunPrefix = "TagHpoDemo"
SimulationSpeed = 4.0
BatchSize = 8
ActionRepeat = 2
CheckpointInterval = 20
AsyncGradientUpdates = true

[sub_resource type="Resource" id="SelfPlayPairing"]
script = ExtResource("5_pairing")
PairingId = "chasers_vs_runners_hpo"
GroupA = ExtResource("6_chasers")
GroupB = ExtResource("7_runners")

[sub_resource type="Resource" id="SelfPlayConfig"]
script = ExtResource("11_selfplay")
